{
  "name": "anc-wargames",
  "private": true,
  "version": "0.0.0",
  "packageManager": "yarn@4.5.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:native": "yarn workspaces foreach --all --parallel --interlaced --jobs unlimited run dev",
    "build": "yarn workspaces foreach --all --topological-dev run build",
    "typecheck": "yarn workspaces foreach --all --topological-dev run typecheck",
    "stop": "docker compose down"
  }
}
